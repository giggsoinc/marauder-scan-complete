# =============================================================
# FILE: .env.example
# PROJECT: PatronAI — Marauder Scan
# VERSION: 1.0.0
# UPDATED: 2026-04-29
# OWNER: Giggso Inc (Ravi Venugopal)
# PURPOSE: Annotated environment template.
#          Copy to .env and fill in the REQUIRED section.
#          Everything else has a safe default.
# USAGE:   cp .env.example .env
# AUDIT LOG:
#   v1.0.0  2026-04-29  Initial.
# =============================================================

# ── REQUIRED — change these 5 values before first start ──────
#
# S3 bucket name (must already exist in your AWS account).
# Create with: aws s3 mb s3://your-bucket-name
PATRONAI_BUCKET=

# Your organisation name — shown in the dashboard header and PDF reports.
COMPANY_NAME=Acme Corp

# URL-safe slug (lowercase, no spaces) — used in S3 path prefixes.
COMPANY_SLUG=acme

# Admin email addresses. These users see every view including Support + Admin.
# Comma-separated, no spaces. Must also appear in ALLOWED_EMAILS.
ADMIN_EMAILS=admin@yourcompany.com

# All users allowed to log in. PatronAI uses email-only auth — there is no
# password field. Add your email here and that is your login credential.
# Comma-separated, no spaces.
ALLOWED_EMAILS=admin@yourcompany.com,analyst@yourcompany.com


# ── AWS CREDENTIALS ───────────────────────────────────────────
# Leave all three blank if running on EC2 with an IAM instance profile
# attached (the recommended production setup — prereqs.sh configures this).
# Fill in only for local dev or if no instance profile is available.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1


# ── ALERTS (optional) ─────────────────────────────────────────
# SNS topic ARN for email/SMS alerts on HIGH and CRITICAL findings.
# Created automatically by prereqs.sh.
# IMPORTANT: after prereqs.sh creates the SNS topic, AWS sends a subscription
# confirmation email to ADMIN_EMAILS. You must click that link — if you miss
# it, alert emails are silently dropped with no error in the logs.
ALERT_SNS_ARN=

# Slack or Teams incoming webhook URL for HIGH/CRITICAL alert messages.
# Leave blank to disable webhook alerts.
TRINITY_WEBHOOK_URL=
LOGANALYZER_WEBHOOK_URL=

# Additional alert recipient emails (beyond ADMIN_EMAILS).
# Comma-separated. These receive alert emails only — not dashboard access.
ALERT_RECIPIENTS=

# From-address for alert emails (must be SES-verified if using SES).
# Defaults to SES_SENDER_EMAIL when generated by setup.sh.
PATRONAI_FROM_EMAIL=noreply@patronai.ai

# ── SES (Simple Email Service) ────────────────────────────────
# Used by the OTP/installer email path (scripts/render_agent_package.py)
# and the welcome-email path (scripts/email_utils.py). Set up via
# scripts/setup.sh — picks single-email or domain (DKIM) verification.
#
# IMPORTANT: SES is regional. If you set up SES in a region different
# from AWS_REGION, set SES_REGION explicitly. Otherwise it defaults to
# AWS_REGION.
#
# IMPORTANT: SES sandbox mode caps you at 200 emails/24h and only
# allows sending to verified addresses. Request production access in
# the SES console: https://console.aws.amazon.com/ses/home#/account
SES_SENDER_EMAIL=
SES_REGION=


# ── DASHBOARD CONFIGURATION (optional) ───────────────────────
# EC2 public IP or DNS without protocol, e.g. your-ec2-instance or your-ec2-instance.compute-1.amazonaws.com
# Used to build deep-link URLs inside alert emails.
PUBLIC_HOST=

# Full Grafana base URL, e.g. http://your-ec2-instance/grafana
# If set, takes precedence over PUBLIC_HOST for Grafana links.
GRAFANA_URL=

# Support-tier users — see Manager + Support views but not Admin.
# Comma-separated. Must also appear in ALLOWED_EMAILS.
SUPPORT_EMAILS=

# CrowdStrike Falcon integration (enterprise only — leave false unless configured).
CROWDSTRIKE_ENABLED=false

# Cloud provider backend for ENI/network metadata resolution.
CLOUD_PROVIDER=aws


# ── LLM CHAT (auto-configured — override only if needed) ─────
# On first `docker compose up`, PatronAI downloads
# LiquidAI/LFM2.5-1.2B-Thinking-GGUF (~750 MB Q4_K_M) into a named
# Docker volume (/models). The dashboard opens immediately; AI chat
# activates once the download finishes (~3-5 min on a typical link).
# You do not need to change anything here for the default experience.
#
# Why LFM2.5-Thinking: native function-calling, small enough for CPU
# inference on a t3.large, surprisingly good at the 8-tool routing
# the chat panel uses.
#
# To use a different local model, change LLM_MODEL_REPO.
# To use an OpenAI-compatible external endpoint, set LLM_BASE_URL +
# LLM_API_KEY (Ollama, Groq, OpenAI, Together, vLLM all work).
LLM_PROVIDER=openai_compat
LLM_BASE_URL=http://localhost:8080
LLM_MODEL=
LLM_API_KEY=
# ⚠ PERF NOTE on the "-Thinking" variant: LFM2.5-1.2B-Thinking emits
# ~500-1000 reasoning tokens BEFORE the answer on every call. We strip
# them in the UI but the CPU still generates them — at ~10 tok/s on a
# t3.large, that's 50-100 sec of extra latency per chat turn just for
# the reasoning preamble.
#
# For production CPU deployments swap to the Instruct variant (no
# reasoning preamble; ~2-3× faster; same tool-calling quality):
#     LLM_MODEL_REPO=LiquidAI/LFM2.5-1.2B-Instruct-GGUF
# Or move to a GPU instance (g5.xlarge ~$1/h gives ~10× speedup) and
# keep -Thinking for slightly better reasoning chains.
LLM_MODEL_REPO=LiquidAI/LFM2.5-1.2B-Thinking-GGUF
# llama-server picks the Q4_K_M quantisation by default for this repo;
# override with LLM_MODEL_FILE only if you want a specific quant.
LLM_MODEL_FILE=
# Read timeout (seconds) — Thinking models emit reasoning tokens before
# tool calls; 60s isn't enough for multi-step tool loops. 180 is safe.
LLM_READ_TIMEOUT_S=180
# Per-completion output cap. Stops a runaway response from blowing
# the chat-context window or burning latency on noise.
LLM_MAX_TOKENS=384
# llama-server slot count. CRITICAL: ctx-size is divided across slots,
# so 4 slots × 8192 ctx = only 2048 tokens per request — chat prompts
# (system + 8 tool schemas + history + tool results) easily exceed
# that. Single-tenant chat = 1 slot. Bump only if multi-tenant.
LLM_PARALLEL_SLOTS=1
# Per-slot context window. 16384 = comfortable headroom for the
# Thinking model's reasoning preamble + chat history + Sources footer.
LLM_CTX_SIZE=16384


# ── SCAN TUNING (optional) ────────────────────────────────────
# How often the scanner reads new events from S3 (seconds).
SCAN_INTERVAL_SECS=300

# Deduplication window — suppress repeat alerts for the same finding.
DEDUP_WINDOW_MINUTES=60

# On first boot, how far back to scan for existing findings (minutes).
LOOKBACK_MINUTES=60

# Minimum number of provider rules before the scanner fires a degraded alert.
STRICT_MIN_RULES=50

# Set to 1 to bake the LFM2.5-1.2B-Thinking GGUF classifier into the
# Docker image (~750 MB extra). Useful for air-gapped deployments.
# Default: 0 (download at runtime via llama-server --hf-repo).
INCLUDE_CLASSIFIER=0
